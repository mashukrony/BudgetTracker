# ── Clerk (https://dashboard.clerk.com → API Keys) ──────────────────────────
# Required on Vercel. Add your production domain under Clerk → Domains.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Hosted sign-in/up paths (must match App Router routes)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Role-aware redirect hub (server sends admins → /admin, users → /dashboard)
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/auth/post-sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/auth/post-sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/auth/post-sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/auth/post-sign-in
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/auth/post-sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/auth/post-sign-in

# Sign-out destination (sidebar + UserButton menu)
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL=/sign-in

# ── Database (PostgreSQL — Neon, Supabase, Vercel Postgres, etc.) ───────────
# DATABASE_URL: pooled connection string for serverless (runtime queries).
# DIRECT_URL: direct/non-pooled connection (migrations only).
# Example (Neon): pooled URL ends with ?sslmode=require; direct URL uses the
# non-pooler host from the Neon dashboard.
DATABASE_URL=
DIRECT_URL=

# ── BudgetBuddy AI chat (/api/chat) ─────────────────────────────────────────
# Google AI Studio key — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
